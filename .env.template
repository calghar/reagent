# AgentGuard Environment Variables
# Copy this file to .env and fill in values

# === LLM Provider API Keys ===
# Set the API key for your chosen LLM provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === LLM Configuration (optional) ===
# Override config.yaml settings via environment
# AGENTGUARD_LLM_PROVIDER=anthropic
# AGENTGUARD_LLM_MODEL=claude-sonnet-4-20250514
# AGENTGUARD_LLM_ENABLED=true

# === Ollama (local models) ===
# OLLAMA_HOST=http://localhost:11434

# === Storage ===
# Override the SQLite database path (defaults to ~/.agentguard/agentguard.db)
# AGENTGUARD_DB_PATH=~/.agentguard/agentguard.db

# === Instinct Extraction ===
# Claude Code session data directory (for 'agentguard instincts extract')
# CLAUDE_PROJECTS_PATH=~/.claude/projects

# === CI Integration ===
# AGENTGUARD_CI=true
