# Reagent Environment Variables
# Copy this file to .env and fill in values

# === LLM Provider API Keys ===
# Set the API key for your chosen LLM provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === LLM Configuration (optional) ===
# Override config.yaml settings via environment
# REAGENT_LLM_PROVIDER=anthropic
# REAGENT_LLM_MODEL=claude-sonnet-4-20250514
# REAGENT_LLM_ENABLED=true

# === Ollama (local models) ===
# OLLAMA_HOST=http://localhost:11434

# === Dashboard ===
# REAGENT_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Path to your local repos, mounted as read-only into the container
# REAGENT_REPOS_PATH=~/repos

# === CI Integration ===
# REAGENT_CI=true
