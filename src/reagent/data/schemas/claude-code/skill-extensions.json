{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Skill Extensions",
  "description": "Claude Code-specific fields beyond the Agent Skills open standard",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "maxLength": 64,
      "description": "Display name, lowercase/numbers/hyphens"
    },
    "description": {
      "type": "string",
      "description": "What the skill does"
    },
    "argument-hint": {
      "type": "string",
      "description": "Hint displayed during autocomplete"
    },
    "disable-model-invocation": {
      "type": "boolean",
      "description": "Prevent auto-loading of this skill"
    },
    "user-invocable": {
      "type": "boolean",
      "description": "Show/hide from slash menu"
    },
    "allowed-tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tools Claude can use without permission when skill active"
    },
    "model": {
      "type": "string",
      "description": "Model to use"
    },
    "effort": {
      "type": "string",
      "enum": ["low", "medium", "high", "max"],
      "description": "Effort level"
    },
    "context": {
      "type": "string",
      "enum": ["fork"],
      "description": "Set to fork for subagent execution"
    },
    "agent": {
      "type": "string",
      "description": "Which subagent type for context:fork"
    },
    "hooks": {
      "type": "object",
      "description": "Scoped hooks for this skill"
    },
    "paths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns limiting skill activation"
    },
    "shell": {
      "type": "string",
      "enum": ["bash", "powershell"],
      "description": "Shell interpreter"
    }
  },
  "additionalProperties": false
}
